{
  "name": "someip-simulation-web",
  "private": true,
  "version": "2.0.0",
  "packageManager": "pnpm@11.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "generate:types": "openapi-typescript ../api/openapi/v1.json -o src/generated/openapi.ts",
    "generate:endpoints": "rtk-query-codegen-openapi openapi-config.mjs",
    "generate:api": "pnpm run generate:types && pnpm run generate:endpoints",
    "test": "vitest run",
    "preview": "vite preview",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/view": "^6.43.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^2.12.0",
    "@uiw/react-codemirror": "^4.23.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "nuqs": "^2.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.76.0",
    "react-redux": "^9.3.0",
    "react-router": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rtk-query/codegen-openapi": "^2.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.6"
  }
}
